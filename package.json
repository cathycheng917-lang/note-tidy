{
  "name": "note-tidy-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20 <=22"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"node --import tsx server/index.ts\" \"vite --host 127.0.0.1 --port 5173\"",
    "dev:client": "vite --host 127.0.0.1 --port 5173",
    "dev:server": "node --import tsx server/index.ts",
    "build": "tsc -p tsconfig.json && tsc -p server/tsconfig.json && vite build",
    "start": "node dist-server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tesseract.js": "4.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.22",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  }
}
